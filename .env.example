# HELIX DASHBOARDS — environment. Copy to .env.local and fill in.

# ── Supabase (required) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Secrets encryption (recommended) — any string; used to AES-encrypt
#    connector tokens stored in connections.config ────────────────────
SECRETS_KEY=

# ── Narrative engine: Ollama first (local/private), else Claude ──────
OLLAMA_BASE_URL=            # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=          # fallback if Ollama not set
CONTENT_MODEL=claude-sonnet-5

# ── GA4 connector (Google OAuth) ────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=  # https://<host>/api/google/callback

# ── Meta long-lived token exchange (optional) ───────────────────────
FB_APP_ID=
FB_APP_SECRET=

# ── HELIX SDR-BDR connector (cross-product metrics import) ───────────
#    Consumer side of the SDR product's /api/export/sdr-metrics endpoint.
#    Per-connection base_url/secret/workspace can be set in the Connect UI;
#    these env vars are the workspace-wide fallback used by the connector.
SDR_EXPORT_URL=            # e.g. https://sdr.helix.example
EXPORT_SECRET=            # must match the SDR bot's EXPORT_SECRET

# ── Delivery channels ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WABA_ID=          # WhatsApp Business Account id — for /api/templates/sync
RESEND_API_KEY=
EMAIL_FROM=HELIX <hello@example.com>

# ── Cron protection (production) ────────────────────────────────────
CRON_SECRET=
